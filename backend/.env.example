# Backend Environment Variables
# Copy this file to .env and configure it for your environment

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Tesera API"

# Security
SECRET_KEY=generate_a_secure_random_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tesera
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}/${POSTGRES_DB}

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AI/LLM — Grok primary, OpenRouter fallback
# Grok API Key almak için: https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-4.3
GROK_BASE_URL=https://api.x.ai/v1

# OpenRouter fallback — Grok kotası/limiti bittiğinde kullanılır
# API Key almak için: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Email
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=info@tesera.com
EMAILS_FROM_NAME="Tesera App"
FRONTEND_URL=http://localhost:3000
