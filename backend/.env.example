# Backend Environment Variables
# Copy this file to .env and configure it for your environment

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Tesera API"

# Security
SECRET_KEY=generate_a_secure_random_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tesera
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}/${POSTGRES_DB}

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AI/LLM — Gemini primary, OpenAI fallback
# Gemini API Key almak için: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# OpenAI fallback — Grok kotası/limiti bittiğinde veya alternatif olarak kullanılır
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Email
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=info@tesera.com
EMAILS_FROM_NAME="Tesera App"
FRONTEND_URL=http://localhost:3000
